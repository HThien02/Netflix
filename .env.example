# Supabase (Next.js đọc .env.local — không phải file .env)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_or_publishable_key
# Dashboard → Settings → API → service_role (secret). Bắt buộc: PayOS pending, webhook, đăng ký user.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_secret_key

# Site — production
APP_URL=https://netflixhub.com.vn
NEXT_PUBLIC_SITE_URL=https://netflixhub.com.vn
CRON_SECRET=your_random_cron_secret
SESSION_SECRET=your_random_session_secret_min_32_chars

# PayOS (returnUrl / webhook dùng APP_URL)
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=
PAYOS_WEBHOOK_URL=https://netflixhub.com.vn/api/payments/payos/webhook

# SePay — chuyển khoản + webhook (Dashboard → Tích hợp → Webhooks)
# API token: my.sepay.vn → Công ty → API (Bearer) — poll giao dịch khi verify nếu webhook chậm
SEPAY_API_TOKEN=
SEPAY_PAYMENT_CODE_PREFIX=NH
# Tên ngân hàng cho QR SePay (vd MBBank) — https://qr.sepay.vn/img?bank=...
SEPAY_BANK_NAME=MBBank
SEPAY_BANK_BIN=970422
SEPAY_BANK_ACCOUNT_NUMBER=
SEPAY_BANK_ACCOUNT_NAME=
SEPAY_WEBHOOK_URL=https://netflixhub.com.vn/api/payments/sepay/webhook
SEPAY_WEBHOOK_AUTH=hmac
SEPAY_WEBHOOK_SECRET=
# SEPAY_WEBHOOK_AUTH=apikey
# SEPAY_WEBHOOK_API_KEY=
# PAYOS_USE_NEXT_CHECKOUT=true
# Đăng ký webhook: POST https://netflixhub.com.vn/api/payments/payos/register-webhook
#   Header: x-cron-secret: CRON_SECRET

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_user@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM_EMAIL=your_smtp_user@gmail.com
SMTP_ADMIN_EMAIL=admin@netflixhub.com.vn
EMAIL_BRAND_NAME=NetflixHub
