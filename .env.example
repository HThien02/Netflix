# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_or_publishable_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# App
APP_URL=http://localhost:3000
CRON_SECRET=your_random_cron_secret
SESSION_SECRET=your_random_session_secret_min_32_chars

# PayOS
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=
# PAYOS_USE_NEXT_CHECKOUT=true
# Webhook — PayOS KHÔNG gọi được localhost. Dùng ngrok hoặc domain deploy:
# PAYOS_WEBHOOK_URL=https://xxxx.ngrok-free.app/api/payments/payos/webhook
# Đăng ký: POST /api/payments/payos/register-webhook  Header: x-cron-secret: CRON_SECRET
#            body: { "webhookUrl": "https://xxxx.ngrok-free.app/api/payments/payos/webhook" }
# SMTP (Gmail, SendGrid, Brevo, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_user@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM_EMAIL=your_smtp_user@gmail.com
SMTP_ADMIN_EMAIL=admin@example.com
EMAIL_BRAND_NAME=TFlowers Shop
